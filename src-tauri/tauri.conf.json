{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenClaw Desktop Wizard",
  "version": "1.2.0",
  "identifier": "com.supaclaw.openclaw-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OpenClaw Desktop Wizard",
        "width": 720,
        "height": 580,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["main-capability"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "longDescription": "Wizard to download, install, configure OpenClaw, run gateway, and install skills and tools.",
    "shortDescription": "OpenClaw desktop setup wizard",
    "category": "DeveloperTool",
    "copyright": "Copyright © 2026 supaclaw",
    "resources": []
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {},
    "process": {
      "all": true
    }
  }
}
